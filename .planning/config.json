{
  "model_profile": "balanced",
  "mode": "interactive",
  "granularity": "standard",
  "project_code": "WFH",
  "commit_docs": true,
  "context_window": 200000,
  "git": {
    "branching_strategy": "none",
    "base_branch": "master"
  },
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "nyquist_validation": true,
    "post_planning_gaps": true,
    "auto_advance": false,
    "skip_discuss": false,
    "ui_phase": true,
    "ui_safety_gate": true,
    "node_repair": true,
    "node_repair_budget": 2,
    "security_enforcement": false,
    "use_worktrees": false,
    "inline_plan_threshold": 2,
    "subagent_timeout": 600000
  },
  "parallelization": true,
  "features": {
    "thinking_partner": true
  },
  "hooks": {
    "context_warnings": true
  }
}
